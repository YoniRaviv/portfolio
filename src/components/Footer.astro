---
import { Image } from 'astro:assets';
import logo from '@/assets/logo-yr-orange.png';
import { site, hero } from '@/content';
const year = new Date().getFullYear();
---
<footer>
  <div class="footer-row">
    <a href="#hero" class="footer-logo" aria-label="Back to top">
      <Image src={logo} alt="YR monogram" width={112} height={112} loading="lazy" />
    </a>
    <div class="footer-meta">
      <span class="copy">© {site.name} · {year}</span>
      <span class="dot">·</span>
      <span>Built with Astro &amp; Three.js</span>
    </div>
    <a href="#hero" class="footer-top">Back to top ↑</a>
  </div>
  <p class="footer-attrib">
    Mask: <a href="https://skfb.ly/6Y9SA" target="_blank" rel="noopener noreferrer">&ldquo;Soulless&rdquo;</a>
    by Ali Rahimi ·
    <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener noreferrer">CC BY 4.0</a>
    · Modified
    <br />
    Katana: <a href="https://skfb.ly/ptK8t" target="_blank" rel="noopener noreferrer">&ldquo;Cyberpunk Enigma - Katana&rdquo;</a>
    by Jysn ·
    <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" target="_blank" rel="noopener noreferrer">CC BY-NC-ND 4.0</a>
  </p>
  <div class="big" aria-hidden="true">{hero.backName}</div>
</footer>

<style>
  footer {
    padding: 40px var(--pad-x) 32px;
    border-top: 1px solid rgba(191, 178, 155, .12);
    font-family: var(--mono); font-size: 11px; letter-spacing: .16em; text-transform: uppercase;
    color: var(--text-dim); position: relative; z-index: 10;
    background-color: var(--main);
  }
  footer .footer-row {
    display: flex; align-items: center; justify-content: space-between;
    gap: 40px;
  }
  footer .footer-logo {
    display: flex; align-items: center;
    text-decoration: none;
    transition: opacity .25s;
  }
  footer .footer-logo:hover { opacity: .7; }
  footer .footer-logo :global(img) { height: 56px; width: auto; opacity: .95; }
  footer .footer-meta { display: flex; align-items: center; gap: 14px; color: var(--text-dim); }
  footer .footer-meta .copy { color: var(--text); }
  footer .footer-meta .dot { opacity: .4; }
  footer .footer-top {
    text-decoration: none; color: var(--text);
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 0;
    position: relative;
    transition: color .25s;
  }
  footer .footer-top::after {
    content: ""; position: absolute; left: 0; right: 0; bottom: 6px; height: 1px;
    background: var(--accent); transform: scaleX(0); transform-origin: right;
    transition: transform .35s cubic-bezier(.2,.7,.2,1);
  }
  footer .footer-top:hover { color: var(--accent); }
  footer .footer-top:hover::after { transform: scaleX(1); transform-origin: left; }

  footer .footer-attrib {
    margin: 24px 0 0;
    font-size: 10px;
    color: var(--text-dim);
    opacity: .8;
  }
  footer .footer-attrib a {
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid rgba(191, 178, 155, .25);
    transition: color .25s, border-color .25s;
  }
  footer .footer-attrib a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  footer .big {
    width: 100%;
    font-family: var(--display); font-weight: 400;
    font-size: clamp(80px, 18vw, 280px);
    line-height: .85; letter-spacing: .005em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(191, 178, 155, .14);
    text-transform: uppercase; text-align: center;
    margin-top: 48px; user-select: none;
    background-image: linear-gradient(to top, var(--accent), var(--accent));
    background-repeat: no-repeat;
    background-size: 100% 0%;
    background-position: bottom center;
    -webkit-background-clip: text;
            background-clip: text;
    transition: background-size .8s cubic-bezier(.65,.05,.36,1), -webkit-text-stroke-color .4s;
    cursor: pointer;
  }
  footer .big:hover {
    background-size: 100% 100%;
    -webkit-text-stroke-color: var(--accent);
  }

  @media (max-width: 720px) {
    footer { padding: 40px var(--pad-x) 32px; gap: 20px; }
    footer .footer-row { flex-direction: column; align-items: flex-start; gap: 24px; }
    footer .footer-logo :global(img) { height: 56px; }
    footer .big { font-size: clamp(80px, 32vw, 200px); margin-top: 32px; }
  }
</style>
