---
import { what, projects } from '@/content';
---
<section class="sec what" id="what" aria-labelledby="what-title" tabindex="-1">
  <div class="sec-label"><span class="num">{what.label.num}</span><span class="lbl">{what.label.text}</span></div>
  <h2 id="what-title" class="visually-hidden">{what.label.text}</h2>

  <div class="projects">
    {projects.map((p) => (
      <a class="proj" href={p.href} data-proj={p.slug}>
        <span class="idx">{p.idx}</span>
        <span class="name reveal-words" data-words>{p.name}</span>
        <span class="desc">
          {p.tags.map((t) => <span class="tag">{t}</span>)}
          {p.desc}
        </span>
        <span class="arrow">→</span>
        <span class="thumb"><span class="placeholder">Drop hero shot ↗</span></span>
      </a>
    ))}
  </div>
</section>

<style>
  .visually-hidden {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
  .what { padding-top: 180px; }
  .what .projects {
    display: flex; flex-direction: column;
    border-top: 1px solid rgba(191, 178, 155, .16);
  }
  .what .proj {
    position: relative;
    border-bottom: 1px solid rgba(191, 178, 155, .16);
    padding: 64px 0;
    display: grid; grid-template-columns: 120px 1fr 420px 80px;
    gap: 48px; align-items: center;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    transition: padding .5s cubic-bezier(.2,.7,.2,1);
  }
  .what .proj:hover { padding: 90px 0; }
  .what .proj .idx {
    font-family: var(--mono); font-size: 11px; letter-spacing: .18em; color: var(--text-dim);
  }
  .what .proj .name {
    font-family: var(--display); font-weight: 400;
    font-size: clamp(72px, 11vw, 200px);
    line-height: 1.0; letter-spacing: .005em; color: #f4eee2;
    position: relative;
    text-transform: uppercase;
    transition: color .4s, transform .5s cubic-bezier(.2,.7,.2,1);
  }
  .what .proj:hover .name { color: var(--accent); transform: translateX(20px); }
  .what .proj .desc {
    font-family: var(--sans); font-size: 14px; line-height: 1.6; color: var(--text);
    max-width: 380px;
  }
  .what .proj .desc .tag {
    display: inline-block; font-family: var(--mono); font-size: 10px; letter-spacing: .16em;
    text-transform: uppercase; color: var(--accent);
    border: 1px solid var(--accent); padding: 3px 8px; border-radius: 2px;
    margin-right: 6px; margin-bottom: 8px;
  }
  .what .proj .arrow {
    font-family: var(--mono); font-size: 32px; color: var(--text-dim);
    text-align: right;
    transition: color .4s, transform .4s;
  }
  .what .proj:hover .arrow { color: var(--accent); transform: translate(8px, -8px); }

  .what .proj .thumb {
    position: absolute; top: 50%; right: 25%; transform: translate(0, -50%) scale(.85);
    width: 280px; height: 180px; pointer-events: none;
    opacity: 0; transition: opacity .5s, transform .6s cubic-bezier(.2,.7,.2,1);
    z-index: 1;
    background: #0b0b0b;
    border: 1px solid rgba(191, 178, 155, .2);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .what .proj:hover .thumb { opacity: 1; transform: translate(0, -50%) scale(1); }
  .what .proj .thumb .placeholder {
    font-family: var(--mono); font-size: 11px; color: var(--text-dim);
    letter-spacing: .16em; text-transform: uppercase;
  }
  .what .proj .thumb::before {
    content: ""; position: absolute; inset: 0;
    background:
      linear-gradient(45deg, transparent 49%, rgba(191,178,155,.05) 49.5%, rgba(191,178,155,.05) 50.5%, transparent 51%),
      linear-gradient(-45deg, transparent 49%, rgba(191,178,155,.05) 49.5%, rgba(191,178,155,.05) 50.5%, transparent 51%);
    background-size: 8px 8px;
  }

  @media (max-width: 1100px) {
    .what .proj { grid-template-columns: 80px 1fr 100px; gap: 24px; }
    .what .proj .desc { grid-column: 2 / span 2; }
    .what .proj .thumb { display: none; }
  }
  @media (max-width: 720px) {
    .what { padding-top: 100px; padding-bottom: 96px; }
    .what .proj { grid-template-columns: 1fr; gap: 12px; padding: 32px 0; }
    .what .proj:hover { padding: 40px 0; }
    .what .proj .idx, .what .proj .arrow { display: none; }
    .what .proj .name { font-size: clamp(56px, 16vw, 88px); line-height: 1; }
    .what .proj .desc { max-width: none; font-size: 13px; }
  }
</style>
