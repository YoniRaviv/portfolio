---
import { Image } from "astro:assets";
import { what, projects } from "@/content";
---

<section class="sec what" id="what" aria-labelledby="what-title" tabindex="-1">
    <div class="sec-label">
        <span class="num">{what.label.num}</span><span class="lbl"
            >{what.label.text}</span>
    </div>
    <h2 id="what-title" class="visually-hidden">{what.label.text}</h2>

    <div class="projects">
        {
            projects.map((p) => (
                <a class="proj" href={p.href} data-proj={p.slug}>
                    <span class="idx">{p.idx}</span>
                    <span class="name reveal-words" data-words>
                        {p.name}
                    </span>
                    <span class="desc">
                        {p.tags.map((t) => (
                            <span class="tag">{t}</span>
                        ))}
                        {p.desc}
                    </span>
                    <span class="arrow">{'→︎'}</span>
                    <span class="thumb">
                        {p.image ? (
                            <Image
                                src={p.image}
                                alt={`${p.name} preview`}
                                width={560}
                                height={360}
                                loading="lazy"
                                decoding="async"
                                class="thumb-img"
                            />
                        ) : (
                            <span class="placeholder">Drop hero shot {'↗︎'}</span>
                        )}
                    </span>
                </a>
            ))
        }
    </div>
</section>

<style>
    .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }
    .what {
        padding-top: 180px;
    }
    .what .projects {
        display: flex;
        flex-direction: column;
        border-top: 1px solid rgba(191, 178, 155, 0.16);
    }
    .what .proj {
        position: relative;
        border-bottom: 1px solid rgba(191, 178, 155, 0.16);
        padding: 64px 0;
        display: grid;
        grid-template-columns: 120px 1fr 420px 80px;
        gap: 48px;
        align-items: center;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
        transition: padding 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
    }
    .what .proj:hover {
        padding: 90px 0;
    }
    .what .proj .idx {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.18em;
        color: var(--text-dim);
    }
    .what .proj .name {
        font-family: var(--display);
        font-weight: 400;
        font-size: clamp(72px, 11vw, 200px);
        line-height: 1;
        letter-spacing: 0.005em;
        color: var(--text-bright);
        position: relative;
        text-transform: uppercase;
        /* Treat hyphenated names like SHI-SHI as one unit so the dash isn't
           used as a soft-break point on narrow columns. */
        overflow-wrap: normal;
        word-break: keep-all;
        hyphens: manual;
        transition:
            color 0.4s,
            transform 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
    }
    .what .proj:hover .name {
        color: var(--accent);
        transform: translateX(20px);
    }
    .what .proj .desc {
        font-family: var(--sans);
        font-size: 14px;
        line-height: 1.6;
        color: var(--text);
        max-width: 380px;
    }
    .what .proj .desc .tag {
        display: inline-block;
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--accent);
        border: 1px solid var(--accent);
        padding: 3px 8px;
        border-radius: 2px;
        margin-right: 6px;
        margin-bottom: 8px;
    }
    .what .proj .arrow {
        font-family: var(--mono);
        font-size: 32px;
        color: var(--text-dim);
        text-align: right;
        transition:
            color 0.4s,
            transform 0.4s;
    }
    .what .proj:hover .arrow {
        color: var(--accent);
        transform: translate(8px, -8px);
    }

    .what .proj .thumb {
        position: absolute;
        top: 50%;
        right: 25%;
        transform: translate(0, -50%) scale(0.85);
        width: 280px;
        height: 180px;
        pointer-events: none;
        opacity: 0;
        transition:
            opacity 0.5s,
            transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1);
        z-index: 1;
        background: #0b0b0b;
        border: 1px solid rgba(191, 178, 155, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    .what .proj:hover .thumb {
        opacity: 1;
        transform: translate(0, -50%) scale(1);
    }
    .what .proj .thumb .placeholder {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--text-dim);
        letter-spacing: 0.16em;
        text-transform: uppercase;
    }
    /* Project hero shot fills the thumb; cover so non-14:9 sources crop
       cleanly. Sits above the checker ::before via z-index. */
    .what .proj .thumb .thumb-img {
        position: relative;
        z-index: 1;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
    .what .proj .thumb::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            linear-gradient(
                45deg,
                transparent 49%,
                rgba(191, 178, 155, 0.05) 49.5%,
                rgba(191, 178, 155, 0.05) 50.5%,
                transparent 51%
            ),
            linear-gradient(
                -45deg,
                transparent 49%,
                rgba(191, 178, 155, 0.05) 49.5%,
                rgba(191, 178, 155, 0.05) 50.5%,
                transparent 51%
            );
        background-size: 8px 8px;
    }
    /* Suppress the checker pattern when a real image is rendered — it's an
       empty-state texture, not chrome. */
    .what .proj .thumb:has(.thumb-img)::before {
        display: none;
    }

    /* True tablets only — phones drop straight to the single-column layout
       below at <=900px so the title isn't squeezed by a sibling column. */
    @media (max-width: 1100px) and (min-width: 901px) {
        .what .proj {
            grid-template-columns: 80px 1fr 100px;
            gap: 24px;
        }
        .what .proj .desc {
            grid-column: 2 / span 2;
        }
        .what .proj .thumb {
            display: none;
        }
    }
    @media (max-width: 900px) {
        .what {
            padding-top: 100px;
            padding-bottom: 96px;
        }
        .what .proj {
            grid-template-columns: 1fr;
            gap: 12px;
            padding: 32px 0;
        }
        .what .proj:hover {
            padding: 40px 0;
        }
        .what .proj .idx,
        .what .proj .arrow,
        .what .proj .thumb {
            display: none;
        }
        .what .proj .name {
            /* 13vw at 375px ≈ 49px; Bebas-Neue "SHI-SHI" fits one line. */
            font-size: clamp(48px, 13vw, 84px);
            line-height: 1;
        }
        .what .proj:hover .name {
            /* Disable the desktop hover slide on touch widths where it pushes
               the long title off-screen. */
            transform: none;
        }
        .what .proj .desc {
            max-width: none;
            font-size: 13px;
        }
    }
</style>
