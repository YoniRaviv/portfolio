---
import { where, roles } from '@/content';
---
<section class="sec where" id="where" aria-labelledby="where-title" tabindex="-1">
  <div class="sec-label"><span class="num">{where.label.num}</span><span class="lbl">{where.label.text}</span></div>
  <div class="header">
    <h2 id="where-title" class="reveal-words" data-words set:html={where.heading}></h2>
    <p class="blurb fade-up">{where.blurb}</p>
  </div>

  <div class="timeline">
    {roles.map((r) => (
      <div class="role fade-up">
        <span class="date">{r.range}</span>
        <span class="company">{r.company}{r.current && (<span class="current">Now</span>)}</span>
        <span class="title">{r.title}</span>
        <span class="city">{r.city}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .where { background: #0e0e0e; padding-top: 200px; padding-bottom: 200px; position: relative; }
  .where::before {
    content: ""; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(to right, transparent, var(--accent), transparent);
    opacity: .35;
  }
  .where .header {
    display: grid; grid-template-columns: 1fr 340px; gap: 60px; align-items: end;
    margin-bottom: 80px;
  }
  .where .header h2 { max-width: 900px; }
  .where h2 {
    font-family: var(--display); font-weight: 400;
    font-size: clamp(64px, 9vw, 150px); line-height: 1.0; letter-spacing: .005em;
    color: var(--text-bright); text-transform: uppercase;
  }
  .where h2 :global(em) { color: var(--accent); font-style: normal; }
  .where .header .blurb {
    font-family: var(--sans); font-size: 16px; line-height: 1.5; color: var(--text);
    max-width: 340px;
  }
  .where .timeline { display: flex; flex-direction: column; }
  .where .role {
    display: grid; grid-template-columns: 180px 1fr 240px 80px;
    gap: 48px; align-items: baseline;
    padding: 36px var(--pad-x);
    margin: 0 calc(var(--pad-x) * -1);
    border-top: 1px solid rgba(191, 178, 155, .16);
    position: relative;
    overflow: hidden;
    isolation: isolate;
    transition: color .35s;
  }
  .where .role:last-child { border-bottom: 1px solid rgba(191, 178, 155, .16); }
  .where .role::before {
    content: "";
    position: absolute; inset: 0;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: center;
    transition: transform .6s cubic-bezier(.65,.05,.36,1);
    z-index: -1;
  }
  .where .role:hover::before { transform: scaleY(1); }
  .where .role > * { transition: color .35s ease; }
  .where .role:hover .date,
  .where .role:hover .company,
  .where .role:hover .title,
  .where .role:hover .city { color: #151515; }
  .where .role:hover .current { color: #151515; }
  .where .role:hover .current::before { background: #151515; box-shadow: none; }
  .where .role .date {
    font-family: var(--mono); font-size: 12px; letter-spacing: .14em; color: var(--text-dim);
    text-transform: uppercase;
  }
  .where .role .company {
    font-family: var(--display); font-weight: 400;
    font-size: clamp(34px, 4.2vw, 64px); line-height: 1; color: var(--text-bright);
    text-transform: uppercase; letter-spacing: .01em;
  }
  .where .role .title {
    font-family: var(--mono); font-size: 12px; letter-spacing: .12em; text-transform: uppercase;
    color: var(--text);
  }
  .where .role .city {
    text-align: right; font-family: var(--mono); font-size: 11px; letter-spacing: .14em;
    text-transform: uppercase; color: var(--text-dim);
  }
  .where .role .current {
    display: inline-flex; align-items: center; gap: 6px;
    color: var(--accent); font-family: var(--mono); font-size: 10px; letter-spacing: .18em;
    text-transform: uppercase; margin-left: 10px;
  }
  .where .role .current::before {
    content: ""; width: 6px; height: 6px; background: var(--accent); border-radius: 50%;
    box-shadow: 0 0 8px var(--accent); animation: pulse 1.8s infinite;
  }

  @media (max-width: 1100px) {
    .where .header { grid-template-columns: 1fr; gap: 24px; }
    .where .role { grid-template-columns: 160px 1fr 200px; gap: 24px; }
    .where .role .city { grid-column: 1 / -1; text-align: left; }
  }
  @media (max-width: 720px) {
    .where .header h2 { font-size: clamp(48px, 13vw, 80px); }
    .where .role { grid-template-columns: 1fr; gap: 8px; padding: 24px var(--pad-x); }
    .where .role .company { font-size: clamp(28px, 8vw, 44px); }
    .where .role .city { text-align: left; grid-column: auto; }
  }
</style>
