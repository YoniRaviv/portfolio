---
import HeroHud from "./HeroScene/HeroHud.astro";
import { hero } from "@/content";
---

<section class="hero" id="hero" aria-labelledby="hero-title" tabindex="-1">
  <div class="scrim"></div>
  <HeroHud />

  <div class="top-meta">
    <div class="col">
      <span>{hero.topMeta.left.label}</span>
      <span class="v">{hero.topMeta.left.value}</span>
      <span>{hero.topMeta.left.sub}</span>
    </div>
    <div class="col r">
      <span>{hero.topMeta.right.label}</span>
      <span class="v">{hero.topMeta.right.value}</span>
      <span>{hero.topMeta.right.sub}</span>
    </div>
  </div>

  <div class="title-block">
    <h1 id="hero-title" class="reveal-words" data-words>
      <span>{hero.firstName}</span><br /><span
        class="swap"
        data-text={hero.lastName}>{hero.lastName}</span
      >
    </h1>
    <div class="role-line">
      <div class="role reveal-words" data-words>{hero.role}</div>
      <div class="signature">
        <span>{hero.signature.primary}</span>
        <span class="a">{hero.signature.accent}</span>
      </div>
    </div>
  </div>

  <div class="scroll-cue">
    <span>{hero.scrollCue}</span>
    <span class="line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    height: 100svh;
    min-height: 620px;
    padding: 0 var(--pad-x);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    z-index: 10;
  }
  .hero .grid-filter {
    position: absolute;
    width: 0;
    height: 0;
    pointer-events: none;
  }
  .hero .scrim {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      radial-gradient(
        ellipse 50% 50% at 70% 45%,
        transparent 0%,
        rgba(21, 21, 21, 0.15) 60%,
        rgba(21, 21, 21, 0.45) 100%
      ),
      linear-gradient(
        to right,
        rgba(21, 21, 21, 0.7) 0%,
        rgba(21, 21, 21, 0) 40%
      ),
      linear-gradient(to bottom, transparent 40%, rgba(21, 21, 21, 0.6) 95%);
  }

  .hero .top-meta {
    position: absolute;
    top: 200px;
    left: var(--pad-x);
    right: var(--pad-x);
    z-index: 3;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .hero .top-meta .col {
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-width: 280px;
  }
  .hero .top-meta .col .v {
    color: var(--text);
  }
  .hero .top-meta .col.r {
    text-align: right;
    align-items: flex-end;
    justify-self: end;
  }
  .hero .top-meta .col {
    animation: metaIn 0.9s cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }
  .hero .top-meta .col:nth-child(1) {
    animation-delay: 0.5s;
  }
  .hero .top-meta .col:nth-child(2) {
    animation-delay: 0.65s;
  }
  @keyframes metaIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
      filter: blur(6px);
    }
    to {
      opacity: 1;
      transform: none;
      filter: none;
    }
  }

  .hero .title-block {
    position: relative;
    z-index: 3;
    padding-bottom: 80px;
  }
  .hero h1 {
    font-family: var(--display);
    font-weight: 400;
    font-size: clamp(72px, 13vw, 220px);
    line-height: 0.92;
    letter-spacing: 0.01em;
    color: var(--text-bright);
    text-transform: uppercase;
  }
  .hero h1 .swap {
    color: var(--accent);
    position: relative;
    display: inline-block;
    font-variant-numeric: tabular-nums;
  }
  .hero h1 br {
    display: block;
  }

  .hero .role-line {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
    margin-top: 28px;
    padding-top: 28px;
    border-top: 1px solid rgba(191, 178, 155, 0.16);
    animation: roleIn 1s cubic-bezier(0.2, 0.7, 0.2, 1) both;
    animation-delay: 1.1s;
  }
  @keyframes roleIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .hero .role-line .role {
    font-family: var(--sans);
    font-size: clamp(16px, 1.4vw, 22px);
    color: var(--text);
    max-width: 520px;
    line-height: 1.5;
    font-weight: 400;
    letter-spacing: 0.01em;
  }
  .hero .role-line .signature {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .hero .role-line .signature .a {
    color: var(--accent);
  }

  .hero .scroll-cue {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    animation: cueIn 0.8s ease both;
    animation-delay: 1.6s;
  }
  @keyframes cueIn {
    from {
      opacity: 0;
      transform: translate(-50%, 20px);
    }
    to {
      opacity: 1;
      transform: translate(-50%, 0);
    }
  }
  .hero .scroll-cue .line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, transparent, var(--accent));
    animation: scrollLine 2s ease-in-out infinite;
  }
  @keyframes scrollLine {
    0% {
      transform: scaleY(0);
      transform-origin: top;
    }
    50% {
      transform: scaleY(1);
      transform-origin: top;
    }
    51% {
      transform: scaleY(1);
      transform-origin: bottom;
    }
    100% {
      transform: scaleY(0);
      transform-origin: bottom;
    }
  }

  @media (max-width: 720px) {
    .hero {
      padding-bottom: 60px;
      padding-top: 100px;
    }
    .hero .scrim {
      background: linear-gradient(
        to bottom,
        rgba(21, 21, 21, 0.55) 0%,
        rgba(21, 21, 21, 0.2) 35%,
        rgba(21, 21, 21, 0.95) 95%
      );
    }
    .hero .top-meta {
      display: none;
    }
    .hero .title-block {
      padding: 20px 0 0;
      position: relative;
    }
    .hero h1 {
      font-size: clamp(56px, 16vw, 100px);
      line-height: 0.95;
    }
    .hero .role-line {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
      margin-top: 24px;
      padding-top: 24px;
    }
    .hero .role-line .role {
      font-size: 15px;
      max-width: none;
    }
    .hero .role-line .signature {
      text-align: left;
      align-items: flex-start;
    }
    .hero .scroll-cue {
      display: none;
    }
  }
  @media (max-width: 420px) {
    .hero h1 {
      font-size: clamp(48px, 17vw, 84px);
    }
  }
</style>
