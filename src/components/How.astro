---
import { how, skillGroups } from '@/content';
---
<section class="sec how" id="how" aria-labelledby="how-title" tabindex="-1">
  <div class="sec-label"><span class="num">{how.label.num}</span><span class="lbl">{how.label.text}</span></div>
  <h2 id="how-title" class="reveal-words" data-words set:html={how.heading}></h2>

  <div class="matrix">
    {skillGroups.map((g) => (
      <div class="row">
        <div class="cat fade-up">
          <span class="idx">{g.idx}</span>
          <span class="label">{g.label}</span>
          <span class="blurb">{g.blurb}</span>
        </div>
        <div class="chips">
          {g.chips.map((c) => (
            <span class={`chip${c.hero ? ' hero-skill' : ''}`}>
              {c.name}<span class="lvl">{c.level}</span>
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .how { padding-top: 160px; padding-bottom: 200px; position: relative; }
  .how h2 {
    font-family: var(--display); font-weight: 400;
    font-size: clamp(56px, 8.5vw, 140px); line-height: 1.0; letter-spacing: .005em;
    color: #f4eee2;
    max-width: 1400px;
    text-transform: uppercase;
  }
  .how h2 :global(em) { color: var(--accent); font-style: normal; }

  .how .matrix { margin-top: 100px; display: flex; flex-direction: column; }
  .how .row {
    display: grid; grid-template-columns: 280px 1fr; gap: 60px;
    padding: 48px 0;
    border-top: 1px solid rgba(191, 178, 155, .14);
    align-items: start;
    transition: background .4s;
  }
  .how .row:last-child { border-bottom: 1px solid rgba(191, 178, 155, .14); }
  .how .row:hover { background: linear-gradient(to right, rgba(255, 111, 89, .04), transparent 60%); }

  .how .row .cat { display: flex; flex-direction: column; gap: 10px; position: sticky; top: 120px; }
  .how .row .cat .idx {
    font-family: var(--mono); font-size: 11px; letter-spacing: .2em; color: var(--accent);
    text-transform: uppercase;
  }
  .how .row .cat .label {
    font-family: var(--display); font-weight: 400;
    font-size: clamp(32px, 4vw, 56px); line-height: 1; color: #f4eee2;
    text-transform: uppercase; letter-spacing: .01em;
  }
  .how .row .cat .blurb {
    font-family: var(--sans); font-size: 13px; color: var(--text-dim); line-height: 1.55;
    max-width: 240px; margin-top: 8px;
  }

  .how .chips { display: flex; flex-wrap: wrap; gap: 10px; padding-top: 8px; }
  .how .chip {
    font-family: var(--mono); font-size: 12px; letter-spacing: .04em;
    padding: 10px 16px; border: 1px solid rgba(191, 178, 155, .2);
    background: transparent; color: var(--text);
    display: inline-flex; align-items: center; gap: 10px;
    border-radius: 2px;
    position: relative; overflow: hidden;
    transition: border-color .3s, color .3s, transform .3s;
    cursor: default;
  }
  .how .chip::before {
    content: ""; position: absolute; inset: 0; background: var(--accent);
    transform: translateY(100%); transition: transform .35s cubic-bezier(.2,.7,.2,1);
    z-index: -1;
  }
  .how .chip:hover { border-color: var(--accent); color: #151515; transform: translateY(-2px); }
  .how .chip:hover::before { transform: translateY(0); }
  .how .chip :global(.lvl) {
    font-size: 10px; color: var(--text-dim); letter-spacing: .12em;
    padding-left: 10px; border-left: 1px solid rgba(191, 178, 155, .25);
    transition: color .3s, border-color .3s;
  }
  .how .chip:hover :global(.lvl) {
    color: rgba(21, 21, 21, .7); border-left-color: rgba(21, 21, 21, .3);
  }
  .how .chip.hero-skill { background: var(--accent); color: #151515; border-color: var(--accent); }
  .how .chip.hero-skill :global(.lvl) {
    color: rgba(21, 21, 21, .7); border-left-color: rgba(21, 21, 21, .3);
  }

  @media (max-width: 1100px) {
    .how .row { grid-template-columns: 1fr; gap: 24px; }
    .how .row .cat { position: static; }
  }
  @media (max-width: 720px) {
    .how h2 { font-size: clamp(48px, 12vw, 72px); }
    .how .row { padding: 32px 0; }
    .how .row .cat .label { font-size: clamp(28px, 8vw, 40px); }
  }
</style>
