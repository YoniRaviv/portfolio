---
// Static fallback shown before Three.js hydrates and when prefers-reduced-motion is set.
---
<div class="hero-placeholder" aria-hidden="true">
  <div class="ring r1"></div>
  <div class="ring r2"></div>
  <div class="ring r3"></div>
  <div class="core"></div>
</div>

<style>
  .hero-placeholder {
    position: absolute; inset: 0;
    display: grid; place-items: center;
    pointer-events: none;
    transition: opacity 0.6s cubic-bezier(.2,.7,.2,1);
  }
  :global([data-loaded='true']) > .hero-placeholder { opacity: 0; }
  .hero-placeholder .core {
    width: 96px; height: 96px;
    background:
      radial-gradient(circle at 50% 50%, var(--accent) 0%, rgba(255,111,89,.6) 30%, transparent 70%);
    filter: blur(2px);
    opacity: .9;
    grid-area: 1 / 1;
    animation: pulse 2.6s ease-in-out infinite;
  }
  .hero-placeholder .ring {
    grid-area: 1 / 1;
    border-radius: 50%;
    border: 1px solid rgba(255, 111, 89, .25);
  }
  .hero-placeholder .r1 { width: 220px; height: 220px; }
  .hero-placeholder .r2 { width: 360px; height: 360px; border-color: rgba(191,178,155,.12); }
  .hero-placeholder .r3 { width: 520px; height: 520px; border-color: rgba(191,178,155,.06); }
</style>
