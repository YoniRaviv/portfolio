---
// Decorative HUD overlay for the hero 3D scene. Pure DOM/SVG + a tiny script
// for mouse parallax. No canvas impact.
---
<div class="hud" aria-hidden="true">
  <span class="bracket tl"></span>
  <span class="bracket tr"></span>
  <span class="bracket bl"></span>
  <span class="bracket br"></span>

  <span class="scanline"></span>

  <svg class="leaders" viewBox="0 0 100 100" preserveAspectRatio="none">
    <line class="lead-scan" x1="14" y1="35" x2="50" y2="20" />
    <line class="lead-eye"  x1="69" y1="48" x2="86" y2="55" />
    <line class="lead-jaw"  x1="51" y1="70" x2="40" y2="78" />
  </svg>

  <div class="target scan">
    <span class="dot"></span>
    <span class="label"><em>SCAN //</em> 87%</span>
  </div>
  <div class="target eye">
    <span class="dot"></span>
    <span class="label">OPTIC // 02<br><em>// CLEAR</em></span>
  </div>
  <div class="target jaw">
    <span class="dot"></span>
    <span class="label">MANDIBLE<br><em>// INTACT</em></span>
  </div>

  <div class="telemetry">
    <div class="row"><span>HR</span><span class="v">072</span><span>BPM</span></div>
    <div class="row"><span>INTG</span><span class="v">94</span><span>%</span></div>
    <div class="row"><span>SIG</span><span class="v ok">OK</span></div>
  </div>
</div>

<script>
  // Mouse parallax: pushes --mx/--my into the .hud element. Each HUD layer
  // multiplies these by a different magnitude to create a sense of depth.
  const hud = document.querySelector('.hud') as HTMLElement | null;
  if (hud && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let tx = 0, ty = 0, mx = 0, my = 0;
    let raf = 0;
    const loop = (): void => {
      mx += (tx - mx) * 0.06;
      my += (ty - my) * 0.06;
      hud.style.setProperty('--mx', mx.toFixed(3));
      hud.style.setProperty('--my', my.toFixed(3));
      if (Math.abs(tx - mx) > 0.0005 || Math.abs(ty - my) > 0.0005) {
        raf = requestAnimationFrame(loop);
      } else {
        raf = 0;
      }
    };
    window.addEventListener('pointermove', (e) => {
      tx = (e.clientX / window.innerWidth - 0.5) * 2;
      ty = (e.clientY / window.innerHeight - 0.5) * 2;
      if (!raf) raf = requestAnimationFrame(loop);
    }, { passive: true });
  }
</script>

<style>
  /* .hud spans the SAME region as the 3D stage (left:30% on desktop), so
     every % inside is relative to the mask area instead of the whole hero.
     That keeps brackets and labels glued to the mask at any viewport size,
     and removes the need for per-breakpoint position overrides. */
  .hud {
    position: absolute;
    top: 0; right: 0; bottom: 0; left: 30%;
    z-index: 3;
    pointer-events: none;
    /* Containment context — lets child `cqh` units (scanline travel) scale
       with the HUD's own height without per-breakpoint overrides. */
    container-type: size;
    --hud-top: 10%;
    --hud-bottom: 20%;
    --hud-left: 9%;
    --hud-right: 6%;
    --mx: 0;
    --my: 0;
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: clamp(9px, 0.9vw, 11px);
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  /* ── Corner brackets (deepest parallax layer) ────────────────── */
  .bracket {
    position: absolute;
    width: 22px; height: 22px;
    border: 1px solid rgba(191, 178, 155, .35);
    opacity: 0;
    animation: hudFadeIn .9s cubic-bezier(.2,.7,.2,1) forwards;
    animation-delay: 1s;
    translate: calc(var(--mx) * -4px) calc(var(--my) * -3px);
    transition: translate .12s linear;
  }
  .bracket.tl { top: var(--hud-top); left: var(--hud-left); border-right: 0; border-bottom: 0; }
  .bracket.tr { top: var(--hud-top); right: var(--hud-right); border-left: 0; border-bottom: 0; animation-delay: 1.05s; }
  .bracket.bl { bottom: var(--hud-bottom); left: var(--hud-left); border-right: 0; border-top: 0; animation-delay: 1.1s; }
  .bracket.br { bottom: var(--hud-bottom); right: var(--hud-right); border-left: 0; border-top: 0; animation-delay: 1.15s; }

  /* ── Scanline sweep (no parallax — its own animation owns transform) ── */
  .scanline {
    position: absolute;
    left: var(--hud-left); right: var(--hud-right);
    top: var(--hud-top);
    height: 1px;
    background: linear-gradient(to right,
      transparent 0%,
      rgba(255, 111, 89, .45) 25%,
      rgba(255, 111, 89, .65) 50%,
      rgba(255, 111, 89, .45) 75%,
      transparent 100%);
    box-shadow: 0 0 6px rgba(255, 111, 89, .35);
    opacity: 0;
    animation: scanSweep 7s cubic-bezier(.5,0,.5,1) infinite;
    animation-delay: 2s;
    /* 70% of HUD height — matches the bracket frame (100 - hud-top - hud-bottom).
       cqh = % of nearest container; scales automatically with HUD on any viewport. */
    --scan-travel: 70cqh;
  }
  @keyframes scanSweep {
    0%   { transform: translateY(0); opacity: 0; }
    8%   { opacity: .8; }
    50%  { transform: translateY(var(--scan-travel)); opacity: .8; }
    92%  { opacity: .8; }
    100% { transform: translateY(0); opacity: 0; }
  }

  /* ── Leader lines (mid parallax) ─────────────────────────────── */
  .leaders {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    stroke: rgba(191, 178, 155, .32);
    stroke-width: .15;
    fill: none;
    translate: calc(var(--mx) * -6px) calc(var(--my) * -4px);
    transition: translate .12s linear;
  }
  .leaders line {
    stroke-dasharray: 200;
    stroke-dashoffset: 200;
    animation: drawLine .7s cubic-bezier(.55,.05,.25,1) forwards;
  }
  .leaders .lead-scan { animation-delay: 1.2s; }
  .leaders .lead-eye  { animation-delay: 1.3s; }
  .leaders .lead-jaw  { animation-delay: 1.4s; }
  @keyframes drawLine {
    to { stroke-dashoffset: 0; }
  }

  /* ── Targets (closest parallax) ──────────────────────────────── */
  .target {
    position: absolute;
    display: flex; align-items: center; gap: 10px;
    translate: calc(var(--mx) * -10px) calc(var(--my) * -7px);
    transition: translate .12s linear;
  }
  .target .dot {
    position: relative;
    width: 8px; height: 8px;
    border: 1px solid var(--accent);
    border-radius: 50%;
    opacity: 0;
    transform: scale(0);
    animation: dotIn .35s cubic-bezier(.2,.9,.3,1.2) forwards;
  }
  .target .dot::after {
    content: '';
    position: absolute; inset: 2px;
    background: var(--accent);
    border-radius: 50%;
    animation: dotPulse 2.2s ease-in-out infinite;
  }
  .target .label {
    color: var(--text);
    line-height: 1.25;
    clip-path: inset(0 100% 0 0);
    animation: labelScan .55s cubic-bezier(.7,0,.3,1) forwards;
  }
  .target .label em {
    font-style: normal;
    color: var(--accent);
  }

  /* Stagger entrance: scan → eye → jaw. Dot precedes label by 180ms. */
  .target.scan .dot   { animation-delay: 1.35s; }
  .target.scan .label { animation-delay: 1.55s; }
  .target.eye  .dot   { animation-delay: 1.5s;  }
  .target.eye  .label { animation-delay: 1.7s;  }
  .target.jaw  .dot   { animation-delay: 1.65s; }
  .target.jaw  .label { animation-delay: 1.85s; }

  /* Positions are now in stage-relative %, so they track the mask. */
  .target.scan {
    top: 35%; left: 3%;
    flex-direction: row-reverse;
    text-align: right;
  }
  .target.eye  {
    top: 54%; right: 1.5%;
  }
  .target.jaw  {
    top: 78%; left: 31%;
  }

  /* ── Telemetry ticker ────────────────────────────────────────── */
  .telemetry {
    position: absolute;
    bottom: calc(var(--hud-bottom) + 32px);
    right: calc(var(--hud-right) + 32px);
    display: flex; flex-direction: column; gap: 4px;
    text-align: right;
    opacity: 0;
    animation: hudFadeIn .9s ease forwards;
    animation-delay: 2s;
    translate: calc(var(--mx) * -6px) calc(var(--my) * -4px);
    transition: translate .12s linear;
  }
  .telemetry .row { display: flex; justify-content: flex-end; gap: 10px; }
  .telemetry .v {
    color: var(--text);
    font-variant-numeric: tabular-nums;
    animation: vFlicker 5s steps(1) infinite;
  }
  .telemetry .v.ok { color: var(--accent); }

  /* ── Keyframes ───────────────────────────────────────────────── */
  @keyframes hudFadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: none; }
  }
  @keyframes dotIn {
    from { opacity: 0; transform: scale(0); }
    to   { opacity: 1; transform: scale(1); }
  }
  @keyframes labelScan {
    from { clip-path: inset(0 100% 0 0); }
    to   { clip-path: inset(0 0 0 0); }
  }
  @keyframes dotPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: .35; transform: scale(.6); }
  }
  @keyframes vFlicker {
    0%, 80%, 100% { opacity: 1; }
    81%, 82%      { opacity: .35; }
  }

  @media (prefers-reduced-motion: reduce) {
    .bracket, .leaders line, .target .dot, .target .label, .telemetry, .scanline {
      animation-duration: .01s !important;
      animation-iteration-count: 1 !important;
    }
    .bracket, .leaders, .target, .telemetry {
      translate: 0 !important;
    }
  }

  @media (max-width: 720px) {
    /* On mobile the .stage is position:relative and sits at the top of the
       hero after .hero's 100px padding-top. Pin the HUD over that same
       region so the brackets keep framing the mask. */
    .hud {
      --hud-top: 0%;
      top: 100px;
      bottom: auto;
      left: 0; right: 0;
      height: max(55vh, 380px);
    }
    /* Keep just the brackets + scanline; drop the readout layers */
    .hud .leaders,
    .hud .target,
    .hud .telemetry {
      display: none;
    }
  }
</style>
