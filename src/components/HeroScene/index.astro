---
// Placeholder now lives inside <HeroHud /> so it can occupy the bracket
// frame using the same --hud-* offsets — keeps the loader and the final
// HUD framing visually aligned.
---

<div class="stage" id="stage"></div>
<div class="moon" id="moon" aria-hidden="true"></div>

<style>
    /* Persistent canvas: now full-viewport so particles aren't clipped to a
     visible right-side frame. The mask itself sits in the right portion of
     the scene via stageGroup.position.x (HERO_RIG), so the visual is the
     same as the old right-70% framing — just without the hard edge. */
    .stage {
        position: fixed;
        inset: 0;
        z-index: 6;
        pointer-events: none;
        animation: stageIn 1.8s cubic-bezier(0.2, 0.7, 0.2, 1) both;
        animation-delay: 0.4s;
    }
    /* --anchor-y is driven by JS once the scroll probe reaches Contact, so the
     canvas stops following the viewport and scrolls with the page. It lives in
     the keyframes (not just on .stage) because animation fill states sit above
     inline styles in the cascade — without var() inside the keyframes, the JS
     transform write would be clobbered by `transform: none` from the `to`
     state. */
    @keyframes stageIn {
        from {
            opacity: 0;
            transform: translate3d(0, var(--anchor-y, 0px), 0) scale(1.08);
            filter: blur(20px);
        }
        to {
            opacity: 1;
            transform: translate3d(0, var(--anchor-y, 0px), 0) scale(1);
            filter: none;
        }
    }
    .stage :global(canvas) {
        display: block;
        width: 100%;
        height: 100%;
    }

    /* Contact moon backdrop. Sits at z-index 5 — below the canvas (z-index 6,
     where the sword renders) and below the sections (z-index 10), so it reads
     as the backmost layer: moon < sword < text. An editorial outline ring with
     a faint accent glow that backlights the embedded blade. opacity starts at 0
     and is raised only by HeroScene.ts as the sword lands (landingProgress), so
     reduced-motion visitors — who never load the scene — never see it, exactly
     as there's no sword for them either. --moon-y mirrors the canvas's
     --anchor-y so the moon scroll-locks to the sword through Contact. */
    .moon {
        position: fixed;
        /* --moon-cx/--moon-cy: blade center, screen px, written by HeroScene.ts so
       the moon stays on the sword. --moon-cy also carries the rise-from-below
       offset that eases to 0 as it lands. Falls back to viewport centre until
       the scene drives them. */
        top: var(--moon-cy, 50%);
        left: var(--moon-cx, 50%);
        width: min(76vh, 82vw);
        aspect-ratio: 1;
        border-radius: 50%;
        z-index: 5;
        pointer-events: none;
        opacity: 0;
        will-change: opacity, top, left;
        transform: translate(-50%, -45%);
        border: 1.5px solid color-mix(in srgb, var(--accent) 50%, transparent);
        background: radial-gradient(
            circle,
            color-mix(in srgb, var(--accent) 12%, transparent) 0%,
            color-mix(in srgb, var(--accent) 4%, transparent) 55%,
            transparent 75%
        );
        box-shadow:
            0 0 46px 9px color-mix(in srgb, var(--accent) 16%, transparent),
            inset 0 0 42px color-mix(in srgb, var(--accent) 8%, transparent);
    }
    /* Mobile: keep it centred but a touch smaller so it doesn't overflow. */
    @media (max-width: 720px) {
        .moon {
            width: min(72vh, 94vw);
        }
    }
</style>

<script>
    // Lazy-load Three.js hero scene only when the stage is in viewport and
    // the user hasn't requested reduced motion. Three.js code-splits into its
    // own chunk via dynamic import.
    const mount = document.getElementById("stage");
    if (mount && !matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const start = () =>
            import("./HeroScene").then(({ init }) => init(mount));
        if ("IntersectionObserver" in window) {
            const io = new IntersectionObserver(
                (entries) => {
                    entries.forEach((e) => {
                        if (e.isIntersecting) {
                            io.disconnect();
                            start();
                        }
                    });
                },
                { rootMargin: "200px" },
            );
            io.observe(mount);
        } else {
            start();
        }
    }
</script>
